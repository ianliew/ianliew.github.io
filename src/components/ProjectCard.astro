---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  href?: string;
}

const { title, description, tags = [], href } = Astro.props;
---

<div class="border border-gray-200 dark:border-gray-800 p-5 hover:border-gray-400 dark:hover:border-gray-600 transition-colors">
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mb-3">
      {tags.map((tag) => (
        <span class="text-xs text-gray-400 dark:text-gray-500 uppercase tracking-wide">{tag}</span>
      ))}
    </div>
  )}
  <h3 class="text-sm font-medium text-gray-900 dark:text-gray-50 mb-2">{title}</h3>
  <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed mb-4">{description}</p>
  {href && (
    <a
      href={href}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs font-medium text-gray-900 dark:text-gray-50 tracking-wide hover:opacity-60 transition-opacity"
    >
      View →
    </a>
  )}
</div>
