---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = [
  {
    title: 'Agentic AI for Investigative Intelligence',
    description: 'Designing next-generation multi-agent AI ecosystems that augment human judgment and scale investigative capacity — built to be adopted incrementally as organisations mature.',
    tags: ['Agentic AI', 'Multi-agent Systems', 'AI Architecture'],
    href: 'https://github.com/ianliew',
  },
  {
    title: 'Logistics Pricing Platform',
    description: 'Co-founded and prototyped a cloud platform connecting shippers and carriers with real-time quotes, targeting deadhead cost recovery for logistics companies.',
    tags: ['Co-founder', 'Cloud', 'SaaS'],
    href: 'https://github.com/ianliew',
  },
];
---

<Base title="Ian Liew">

  {/* Hero */}
  <section class="max-w-3xl mx-auto px-6 pt-36 pb-20 border-b border-gray-100 dark:border-gray-800">
    <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gray-400 dark:text-gray-500 mb-5">
      Hong Kong SAR
    </p>
    <h1 class="text-4xl sm:text-5xl font-light text-gray-900 dark:text-gray-50 leading-tight tracking-tight mb-5">
      I build the systems that<br />make transformation real.
    </h1>
    <div class="w-10 h-px bg-gray-900 dark:bg-gray-50 mb-6"></div>
    <p class="text-base text-gray-500 dark:text-gray-400 leading-relaxed max-w-lg mb-8">
      Director at Deloitte. Solutions architect at heart. 20 years of turning complex ideas into working systems — from data platforms and analytics to agentic AI.
    </p>
    <div class="flex flex-wrap gap-3">
      <a href="/work" class="inline-block bg-gray-900 dark:bg-gray-50 text-white dark:text-gray-900 text-xs font-medium tracking-wide px-5 py-2.5 hover:opacity-80 transition-opacity">
        View Work →
      </a>
      <a href="/blog" class="inline-block border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400 text-xs font-medium px-5 py-2.5 hover:border-gray-400 dark:hover:border-gray-500 transition-colors">
        Read Blog →
      </a>
    </div>
  </section>

  {/* About */}
  <section id="about" class="max-w-3xl mx-auto px-6 py-20 border-b border-gray-100 dark:border-gray-800">
    <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gray-400 dark:text-gray-500 mb-6">About</p>
    <div class="flex flex-col sm:flex-row gap-8 sm:gap-12">
      <div class="flex-1">
        <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed mb-4">
          I'm Ian. I don't reimagine business processes — I figure out how to make them real. Give me a vision, a strategic objective, or an AI ambition, and I'll architect the system, plan the delivery, and ship it. I've done this across financial services, telecoms, aviation, and government — in Australia, the US, Hong Kong, and mainland China.
        </p>
        <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
          These days I lead AI-driven transformation at Deloitte. Find me on <a href="https://github.com/ianliew" class="text-gray-900 dark:text-gray-50 underline underline-offset-2">GitHub</a> or <a href="https://linkedin.com/in/ianliew" class="text-gray-900 dark:text-gray-50 underline underline-offset-2">LinkedIn</a>.
        </p>
      </div>
      <div class="w-20 h-20 flex-shrink-0 bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-xs text-gray-400">
        Photo
      </div>
    </div>
  </section>

  {/* Featured Work */}
  <section id="work" class="max-w-3xl mx-auto px-6 py-20 border-b border-gray-100 dark:border-gray-800">
    <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gray-400 dark:text-gray-500 mb-6">Featured Work</p>
    <div class="grid sm:grid-cols-2 gap-4 mb-6">
      {projects.map((p) => <ProjectCard {...p} />)}
    </div>
    <a href="/work" class="text-xs font-medium text-gray-900 dark:text-gray-50 tracking-wide hover:opacity-60 transition-opacity">
      See all work →
    </a>
  </section>

  {/* Latest Posts */}
  <section id="blog" class="max-w-3xl mx-auto px-6 py-20">
    <p class="text-xs font-semibold tracking-[0.2em] uppercase text-gray-400 dark:text-gray-500 mb-6">Latest Posts</p>
    <div class="border-t border-gray-100 dark:border-gray-800">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
    <div class="mt-6">
      <a href="/blog" class="text-xs font-medium text-gray-900 dark:text-gray-50 tracking-wide hover:opacity-60 transition-opacity">
        All posts →
      </a>
    </div>
  </section>

</Base>
